# OpenAI API Key (set one provider)
OPENAI_API_KEY=sk-proj-...

# Anthropic API Key (optional alternative)
ANTHROPIC_API_KEY=

# Runtime
PORT=8787
HOST=0.0.0.0

# Security: use a long random value in production
ACCESS_CODE=replace-with-long-random-secret

# Comma separated list of allowed frontend origins
# Example: https://your-app.vercel.app,https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# Session lifetime (7 days)
SESSION_TTL_MS=604800000

# AI model/provider
AI_MODEL=gpt-4o
AI_PROVIDER=openai
