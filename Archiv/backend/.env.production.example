# Required: choose one provider
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=

# Required security secret
ACCESS_CODE=replace-with-long-random-secret

# Render/hosting runtime
PORT=8787
HOST=0.0.0.0

# Restrict browser origins to your deployed frontend domain(s)
# Example:
# CORS_ORIGINS=https://finova.vercel.app,https://app.finova.com
CORS_ORIGINS=https://your-frontend.vercel.app

# Session lifetime in milliseconds (7 days)
SESSION_TTL_MS=604800000

# AI setup
AI_PROVIDER=openai
AI_MODEL=gpt-4o
